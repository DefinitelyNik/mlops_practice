pipeline {
    agent any
    
    environment {
        PYTHON_VENV = "${WORKSPACE}/lab2/venv"
        DATA_DIR = "${WORKSPACE}/lab2/artifacts/data"
        MODEL_DIR = "${WORKSPACE}/lab2/artifacts/models"
        REPORT_DIR = "${WORKSPACE}/lab2/artifacts/reports"
    }
    
    stages {
        stage('Checkout') {
            steps {
                checkout scm
                echo "✅ Код получен из репозитория"
            }
        }
        
        stage('Setup Python') {
            steps {
                script {
                    sh '''
                        cd lab2
                        python3 -m venv venv
                        source venv/bin/activate
                        pip install --upgrade pip
                        pip install -r requirements.txt
                    '''
                }
            }
        }
        
        stage('Data Creation') {
            steps {
                script {
                    sh '''
                        source ${PYTHON_VENV}/bin/activate
                        cd lab2
                        python data_creation.py --output-dir ${DATA_DIR}
                    '''
                }
            }
        }
        
        stage('Data Preprocessing') {
            steps {
                script {
                    sh '''
                        source ${PYTHON_VENV}/bin/activate
                        cd lab2
                        python data_preprocessing.py --data-dir ${DATA_DIR} --output-dir ${DATA_DIR}
                    '''
                }
            }
        }
        
        stage('Model Training') {
            steps {
                script {
                    sh '''
                        source ${PYTHON_VENV}/bin/activate
                        cd lab2
                        python model_preparation.py --data-dir ${DATA_DIR} --model-dir ${MODEL_DIR}
                    '''
                }
            }
        }
        
        stage('Model Testing') {
            steps {
                script {
                    sh '''
                        source ${PYTHON_VENV}/bin/activate
                        cd lab2
                        python model_testing.py --data-dir ${DATA_DIR} --model-dir ${MODEL_DIR} --report-dir ${REPORT_DIR}
                    '''
                }
            }
        }
    }
    
    post {
        always {
            cleanWs(
                cleanWhenAborted: false,
                notFailBuild: true,
                deleteDirs: true,
                disableDeferredWipeout: false
            )
        }
        failure {
            echo "❌ Ошибка в пайплайне. Проверьте Console Output."
        }
        success {
            echo "🎉 Сборка успешна!"
        }
    }
}